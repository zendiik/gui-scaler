{
    "schemaVersion": 1,
    "id": "guiscaler",
    "version": "${display_version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "sources": "https://github.com/zendiik/gui-scaler",
        "issues": "https://github.com/zendiik/gui-scaler/issues"
    },
    "license": "${license}",
    "icon": "${mod_id}.png",
    "environment": "client",
    "entrypoints": {
        "main": [
            "eu.netleak.guiscaler.GuiScaler"
        ],
        "modmenu": [
            "eu.netleak.guiscaler.GuiScalerModMenuIntegration"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.14",
        "fabric-api": "*",
        "minecraft": "${minecraft_version}",
        "java": ">=${java_version}",
        "cloth-config2": ">=11.0.0"
    }
}
